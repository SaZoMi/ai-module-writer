TAKARO_USERNAME=my-user@example.com
TAKARO_PASSWORD="xxx"
TAKARO_HOST=https://api.takaro.io
TAKARO_DOMAIN_ID=major-cougars-tell

# Registration token from Takaro: Game Servers → Add Server
TAKARO_REGISTRATION_TOKEN=your-registration-token-here

# Minecraft Paper Server Configuration
TAKARO_MC_IDENTITY_TOKEN=unique-mc-identity
RCON_PASSWORD=takaro123
TAKARO_WS_URL=wss://connect.takaro.io
TAKARO_PLUGIN_VERSION=0.0.5

# Multi-instance support
# Set INSTANCE_ID (0-9) to run multiple clones simultaneously.
# Then run: source scripts/instance-env.sh
# This auto-sets the port vars below based on INSTANCE_ID.
INSTANCE_ID=0
MC_PORT=25665
RCON_PORT=25675
BOT_PORT=3101
REDIS_PORT=6379
